      "headerHeightMobile": { "$type": "dimension", "$value": "64px" },
      "sectionPaddingY": { "$type": "dimension", "$value": "96px" },
      "sectionPaddingYTablet": { "$type": "dimension", "$value": "64px" },
      "sectionPaddingYMobile": { "$type": "dimension", "$value": "48px" }
