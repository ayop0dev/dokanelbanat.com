      "none": { "$type": "shadow", "$value": { "color": "#000000", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "0px" } },
      "card": { "$type": "shadow", "$value": [
        { "color": "rgba(26,5,18,0.06)", "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px" },
        { "color": "rgba(26,5,18,0.04)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
      ]},
      "dropdown": { "$type": "shadow", "$value": [
        { "color": "rgba(26,5,18,0.08)", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" },
        { "color": "rgba(26,5,18,0.04)", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0px" }
      ]},
      "modal": { "$type": "shadow", "$value": [
        { "color": "rgba(26,5,18,0.12)", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" },
        { "color": "rgba(26,5,18,0.06)", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" }
      ]}
