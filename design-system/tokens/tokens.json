          "label": { "$type": "number", "$value": 1.4 },
          "button": { "$type": "number", "$value": 1.2 }
        },
        "en": {
          "display": { "$type": "number", "$value": 1.05 },
          "h1": { "$type": "number", "$value": 1.1 },
          "h2": { "$type": "number", "$value": 1.15 },
          "h3": { "$type": "number", "$value": 1.2 },
          "h4": { "$type": "number", "$value": 1.25 },
          "h5": { "$type": "number", "$value": 1.3 },
          "h6": { "$type": "number", "$value": 1.4 },
          "bodyLg": { "$type": "number", "$value": 1.6 },
          "body": { "$type": "number", "$value": 1.6 },
          "bodySm": { "$type": "number", "$value": 1.5 },
          "caption": { "$type": "number", "$value": 1.4 },
          "label": { "$type": "number", "$value": 1.2 },
          "button": { "$type": "number", "$value": 1.0 }
