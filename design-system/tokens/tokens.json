    "motion": {
      "ease": {
        "editorial": { "$type": "cubicBezier", "$value": [0.32, 0.72, 0, 1] },
        "editorialQuick": { "$type": "cubicBezier", "$value": [0.25, 0.46, 0.45, 0.94] },
        "editorialEmphasis": { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] }
      },
      "duration": {
        "instant": { "$type": "duration", "$value": "100ms" },
        "quick": { "$type": "duration", "$value": "200ms" },
        "default": { "$type": "duration", "$value": "300ms" },
        "slow": { "$type": "duration", "$value": "500ms" }
      }
