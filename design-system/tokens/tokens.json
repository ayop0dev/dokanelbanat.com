        "orange": { "$type": "color", "$value": "#ff6b4a" },
        "yellow": { "$type": "color", "$value": "#ffbe3d" },
        "green": { "$type": "color", "$value": "#3db5aa" },
        "light": { "$type": "color", "$value": "#fff5fb", "$description": "Canvas background" },
        "border": { "$type": "color", "$value": "#ffbfe8" },
        "primaryDark": { "$type": "color", "$value": "#cc007f", "$description": "Hover/active state" },
        "primaryLight": { "$type": "color", "$value": "#ff66c4" },
        "greenDark": { "$type": "color", "$value": "#2a9088" }
      },
      "semantic": {
        "bgBase": { "$type": "color", "$value": "#ffffff" },
        "bgCanvas": { "$type": "color", "$value": "{color.brand.light}" },
        "bgSurface": { "$type": "color", "$value": "#ffffff" },
        "bgSurfaceRaised": { "$type": "color", "$value": "#ffffff" },
        "bgInverse": { "$type": "color", "$value": "#1a0512" },
