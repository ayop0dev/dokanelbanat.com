{
  "$schema": "https://design-tokens.github.io/community-group/format/schemas/w3c.json",
  "name": "dokanelbanat Design Tokens",
  "version": "1.0.0",
  "description": "Production-ready design tokens for dokanelbanat.com — Editorial Conscious Femininity. Arabic (RTL) primary.",
  "tokens": {
    "color": {
      "brand": {
        "primary": { "$type": "color", "$value": "#ff009f", "$description": "Primary brand pink — statement color" },
