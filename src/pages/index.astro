---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import MagazineGrid from '../components/MagazineGrid.astro';
import Vision from '../components/Vision.astro';
import Numbers from '../components/Numbers.astro';
import ProductsGrid from '../components/ProductsGrid.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout>
  <Header />
  <main class="ds-landing-page">
    <Hero />
    <About />
    <MagazineGrid />
    <Vision />
    <Numbers />
    <ProductsGrid />
    <CtaBanner />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  /* ── Hero tweaks ── */
  .ds-hero {
    min-height: 100vh;
    padding-block: 0;
  }

  .ds-hero__inner {
    min-height: 100vh;
  }

  .ds-hero__content {
    align-self: center;
  }

  .ds-landing-page__section+.ds-landing-page__section {
    border-top: none;
  }

  /* ── Extra-large button (beyond design system) ── */
  .ds-btn--xl {
    padding: var(--space-5) var(--space-8);
  }

  /* ── Hero vertical sliders ── */
  .hero-sliders {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    position: absolute;
    inset: -25% 0;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);
  }

  .hero-slider {
    overflow: hidden;
  }

  .hero-slider__track {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    will-change: transform;
  }

  .hero-slider--up .hero-slider__track {
    animation: hero-slide-up 28s linear infinite;
  }

  .hero-slider--down .hero-slider__track {
    animation: hero-slide-down 28s linear infinite;
  }

  @keyframes hero-slide-up {
    from {
      transform: translateY(0);
    }

    to {
      transform: translateY(-50%);
    }
  }

  @keyframes hero-slide-down {
    from {
      transform: translateY(-50%);
    }

    to {
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slider__track {
      animation: none !important;
    }
  }

  .hero-slide-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--color-bg-canvas);
    border: 1px solid var(--color-border-default);
    display: block;
    object-fit: cover;
  }

  /* ── Press release: centered with bg image overlay ── */
  .ds-press-release {
    position: relative;
    background: url('https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;
  }

  .ds-press-release::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 0, 159, 0.92) 0%, rgba(204, 0, 127, 0.92) 100%);
    z-index: 0;
  }

  .ds-press-release__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ds-press-release__title,
  .ds-press-release__body {
    margin-inline: auto;
  }

  .ds-announcement {
    text-align: start;
    max-width: 720px;
    margin-inline: auto;
    background: rgba(255, 255, 255, 0.95);
    color: var(--color-text-primary);
    border-inline-start: 4px solid var(--color-primary);
    padding: var(--space-5) var(--space-5) var(--space-5) var(--space-6);
  }

  .ds-announcement__title {
    color: var(--color-text-primary);
  }

  .ds-announcement__body {
    max-width: 65ch;
    color: var(--color-text-secondary);
  }

  /* ── Pillars 2×2 grid ── */
  .pillars-2x2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gutter);
  }

  @media (max-width: 640px) {
    .pillars-2x2 {
      grid-template-columns: 1fr;
    }
  }

  /* ── Magazine 5-card layout ── */
  .magazine-5 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--grid-gutter);
  }

  .magazine-5 .ds-article-card--featured {
    grid-row: 1 / 3;
  }

  .magazine-5__right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--grid-gutter);
    grid-row: 1 / 3;
  }

  @media (max-width: 1024px) {
    .magazine-5 {
      grid-template-columns: 1fr;
    }

    .magazine-5 .ds-article-card--featured {
      grid-row: auto;
    }

    .magazine-5__right {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .magazine-5__right {
      grid-template-columns: 1fr;
    }
  }

  /* ── Vision / Mission icons & bigger type ── */
  .vision-icon,
  .mission-icon {
    width: 48px;
    height: 48px;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .ds-two-column__label {
    font: var(--type-ar-h6);
    letter-spacing: var(--letter-spacing-ar-h6);
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .ds-two-column__title {
    font: var(--type-ar-h2);
    letter-spacing: var(--letter-spacing-ar-h2);
  }
</style>
