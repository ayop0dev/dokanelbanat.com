---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getAllProductSlugs, getProductBySlug } from '../../lib/woocommerce.js';

export async function getStaticPaths() {
  return await getAllProductSlugs();
}

const { slug } = Astro.params;
const product = await getProductBySlug(slug);

if (!product) {
  return Astro.redirect('/404');
}

const title = `${product.name} - دكان البنات`;
const description = product.shortDescription || 'منتج رقمي من دكان البنات.';
const image = product.image?.src ?? '';

const isFree = product.price === 'مجاني';
---

<BaseLayout title={title} description={description} ogImage={image}>
  <main class="product-landing">
    {/* 1. Editorial Product Masthead */}
    <header class="product-masthead">
      <div class="product-masthead__container">
        <nav class="product-masthead__nav" aria-label="العودة للمنتجات">
          <a href="/products" class="ds-btn ds-btn--ghost ds-btn--sm">← كل المنتجات</a>
        </nav>

        <div class:list={["product-masthead__layout", { "product-masthead__layout--no-image": !product.image }]}>
          <div class="product-masthead__content">
            {product.category && <span class="ds-section-label">{product.category}</span>}
            <h1 class="product-masthead__title">{product.name}</h1>
            {product.shortDescription && <p class="product-masthead__short-desc">{product.shortDescription}</p>}

            <div class="product-masthead__cta-box">
              <span class:list={["product-masthead__price", { "product-masthead__price--free": isFree }]}>{product.price}</span>
              {product.isInStock ? (
                <a href={product.checkoutUrl} class="ds-btn ds-btn--primary-solid ds-btn--lg ds-btn--pill product-masthead__btn">
                  {isFree ? 'احصلي عليه مجانًا' : 'إتمام الشراء'}
                </a>
              ) : (
                <button class="ds-btn ds-btn--primary-solid ds-btn--lg ds-btn--pill product-masthead__btn" disabled>
                  غير متاح حاليًا
                </button>
              )}
              {product.isInStock ? (
                <p class="product-masthead__note">منتج رقمي يصلك بعد إتمام الطلب</p>
              ) : (
                <p class="product-masthead__note">هنعلن بمجرد ما يكون المنتج متاح</p>
              )}
            </div>
          </div>

          {product.image && (
            <div class="product-masthead__visual">
              <img src={product.image.src} alt={product.image.alt} class="product-masthead__cover" />
            </div>
          )}
        </div>
      </div>
    </header>

    {/* 2. Value Statement */}
    <section class="value-statement">
      <div class="value-statement__container">
        <h2 class="value-statement__title">خطوة صغيرة لنفسك ممكن تعمل فرق كبير</h2>
        <ul class="value-statement__list">
          <li>
            <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            <span>منتج رقمي</span>
          </li>
          <li>
            <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            <span>استخدام بسيط</span>
          </li>
          <li>
            <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
            <span>وصول سريع</span>
          </li>
        </ul>
      </div>
    </section>

    {/* 3. Product Story */}
    {product.description && (
      <section class="product-story">
        <div class="product-story__container">
          <h2 class="product-story__heading">ليه المنتج ده معمول ليكي؟</h2>
          <div class="product-story__prose" set:html={product.description} />
        </div>
      </section>
    )}

    {/* 5. How to get the product */}
    <section class="how-to-get">
      <div class="how-to-get__container">
        <ol class="how-to-get__steps">
          <li>
            <span class="how-to-get__number ds-index-number">١</span>
            <span class="how-to-get__text">
              {isFree ? 'اضغطي على “احصلي عليه مجانًا”' : 'اضغطي على “إتمام الشراء”'}
            </span>
          </li>
          <li>
            <span class="how-to-get__number ds-index-number">٢</span>
            <span class="how-to-get__text">كمّلي بيانات الطلب</span>
          </li>
          <li>
            <span class="how-to-get__number ds-index-number">٣</span>
            <span class="how-to-get__text">حمّلي منتجك وابدئي استخدامه</span>
          </li>
        </ol>
      </div>
    </section>

    {/* 6. Final Conversion Section */}
    <section class="final-conversion">
      <div class="final-conversion__container">
        {product.image && (
          <img src={product.image.src} alt={product.image.alt} class="final-conversion__cover" loading="lazy" />
        )}
        <h2 class="final-conversion__title">{product.name}</h2>
        <p class:list={["final-conversion__price", { "final-conversion__price--free": isFree }]}>{product.price}</p>
        <p class="final-conversion__subtitle">جاهزة تعملي خطوة صغيرة لنفسك؟</p>
        {product.isInStock ? (
          <a href={product.checkoutUrl} class="ds-btn ds-btn--primary-solid ds-btn--lg ds-btn--pill final-conversion__btn">
            {isFree ? 'احصلي عليه مجانًا' : 'إتمام الشراء'}
          </a>
        ) : (
          <button class="ds-btn ds-btn--primary-solid ds-btn--lg ds-btn--pill final-conversion__btn" disabled>
            غير متاح حاليًا
          </button>
        )}
        {product.isInStock ? (
          <p class="final-conversion__note">منتج رقمي يصلك بعد إتمام الطلب</p>
        ) : (
          <p class="final-conversion__note">هنعلن بمجرد ما يكون المنتج متاح</p>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
.product-landing {
  background-color: var(--color-bg-base);
  overflow-x: hidden;
}

/* 1. Masthead */
.product-masthead {
  padding-block: var(--space-4) var(--space-8);
  background: var(--color-bg-canvas);
}

@media (min-width: 1024px) {
  .product-masthead {
    padding-block: var(--space-8) var(--space-16);
  }
}

.product-masthead__container {
  max-width: var(--grid-max-width);
  margin-inline: auto;
  padding-inline: var(--grid-margin);
}

.product-masthead__nav {
  margin-bottom: var(--space-4);
}

@media (min-width: 1024px) {
  .product-masthead__nav {
    margin-bottom: var(--space-8);
  }
}

.product-masthead__layout {
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  gap: var(--space-8);
  max-width: 800px;
  margin-inline: auto;
}

.product-masthead__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 100%;
}

.product-masthead__title {
  font: var(--type-ar-h2);
  color: var(--color-text-primary);
  margin-bottom: var(--space-2);
}

.product-masthead__short-desc {
  font: var(--type-ar-body-lg);
  color: var(--color-text-secondary);
  line-height: 1.8;
  margin-bottom: var(--space-8);
  max-width: 45ch;
}

.product-masthead__cta-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: var(--space-6);
  margin-top: var(--space-6);
  border-top: 1px solid var(--color-border-default);
  width: 100%;
  max-width: 320px;
}

.product-masthead__price {
  font: var(--type-ar-h3);
  color: var(--color-text-primary);
  margin-bottom: var(--space-4);
}

.product-masthead__price--free {
  color: var(--color-primary);
}

.product-masthead__btn {
  width: 100%;
  margin-bottom: var(--space-3);
}

.product-masthead__note {
  font: var(--type-ar-caption);
  color: var(--color-text-muted);
  text-align: center;
  width: 100%;
}

.product-masthead__visual {
  position: relative;
  width: 100%;
  max-width: 400px;
  margin-inline: auto;
  border-radius: var(--radius-sm);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-masthead__cover {
  width: 100%;
  height: auto;
  object-fit: contain;
  box-shadow: none;
  border-radius: var(--radius-sm);
}

/* 2. Value Statement */
.value-statement {
  padding-block: var(--space-6);
  border-bottom: 1px solid var(--color-border-default);
  background: var(--color-bg-base);
}

@media (min-width: 768px) {
  .value-statement {
    padding-block: var(--space-8);
  }
}

.value-statement__container {
  max-width: var(--grid-max-width);
  margin-inline: auto;
  padding-inline: var(--grid-margin);
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

@media (min-width: 768px) {
  .value-statement__container {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.value-statement__title {
  font: var(--type-ar-h2);
  color: var(--color-primary);
  text-align: center;
}

.value-statement__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-6);
  font: var(--type-ar-label);
  color: var(--color-text-primary);
}

@media (min-width: 768px) {
  .value-statement__list {
    flex-direction: row;
    justify-content: center;
  }
}

.value-statement__list li {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-2);
}

@media (min-width: 768px) {
  .value-statement__list li {
    flex-direction: row;
  }
}

.value-statement__list li svg {
  color: var(--color-primary);
  width: 1.5rem;
  height: 1.5rem;
}

/* 3. Product Story */
.product-story {
  padding-block: var(--space-8);
  background: var(--color-bg-base);
}

@media (min-width: 768px) {
  .product-story {
    padding-block: var(--space-10);
  }
}

.product-story__container {
  max-width: 800px;
  margin-inline: auto;
  padding-inline: var(--grid-margin);
}

.product-story__heading {
  font: var(--type-ar-h2);
  color: var(--color-text-primary);
  margin-bottom: var(--space-6);
  text-align: center;
}

.product-story__prose :global(h1),
.product-story__prose :global(h2),
.product-story__prose :global(h3),
.product-story__prose :global(h4) {
  font-family: var(--font-headline);
  color: var(--color-text-primary);
  margin-top: var(--space-8);
  margin-bottom: var(--space-4);
}

.product-story__prose :global(h1) { font: var(--type-ar-h2); }
.product-story__prose :global(h2) { font: var(--type-ar-h3); }
.product-story__prose :global(h3) { font: var(--type-ar-h4); }
.product-story__prose :global(h4) { font: var(--type-ar-h5); }

.product-story__prose :global(p),
.product-story__prose :global(li) {
  font: var(--type-ar-body-lg);
  color: var(--color-text-secondary);
  line-height: 1.9;
  margin-bottom: var(--space-4);
}

.product-story__prose :global(ul),
.product-story__prose :global(ol) {
  margin-block: var(--space-4);
  padding-inline-start: var(--space-6);
}

.product-story__prose :global(img) {
  max-width: 100%;
  height: auto;
  border-radius: var(--radius-sm);
  margin-block: var(--space-6);
}

/* 5. How to get the product */
.how-to-get {
  padding-block: var(--space-8);
  background: var(--color-bg-base);
  border-top: 1px solid var(--color-border-default);
}

@media (min-width: 768px) {
  .how-to-get {
    padding-block: var(--space-10);
  }
}

.how-to-get__container {
  max-width: var(--grid-max-width);
  margin-inline: auto;
  padding-inline: var(--grid-margin);
}

.how-to-get__steps {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

@media (min-width: 768px) {
  .how-to-get__steps {
    flex-direction: row;
    justify-content: center;
    gap: var(--space-8);
  }
}

.how-to-get__steps li {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-2);
  flex: 1;
}

.how-to-get__number {
  font: var(--type-ar-h2);
  color: var(--color-primary);
  line-height: 1;
}

.how-to-get__text {
  font: var(--type-ar-label);
  color: var(--color-text-primary);
}

@media (min-width: 768px) {
  .how-to-get__text {
    font: var(--type-ar-body-lg);
  }
}

/* 6. Final Conversion Section */
.final-conversion {
  padding-block: var(--space-8);
  background: var(--color-bg-canvas);
  text-align: center;
}

@media (min-width: 768px) {
  .final-conversion {
    padding-block: var(--space-12);
  }
}

.final-conversion__container {
  max-width: 600px;
  margin-inline: auto;
  padding-inline: var(--grid-margin);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.final-conversion__cover {
  width: 140px;
  height: auto;
  object-fit: contain;
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-6);
}

@media (min-width: 768px) {
  .final-conversion__cover {
    width: 180px;
  }
}

.final-conversion__title {
  font: var(--type-ar-h2);
  color: var(--color-text-primary);
  margin-bottom: var(--space-2);
}

.final-conversion__price {
  font: var(--type-ar-h3);
  color: var(--color-text-primary);
  margin-bottom: var(--space-6);
}

.final-conversion__price--free {
  color: var(--color-primary);
}

.final-conversion__subtitle {
  font: var(--type-ar-body-lg);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-8);
}

.final-conversion__btn {
  width: 100%;
  max-width: 320px;
  margin-bottom: var(--space-3);
}

.final-conversion__note {
  font: var(--type-ar-caption);
  color: var(--color-text-muted);
  margin-top: var(--space-2);
}
</style>
