---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getProductById } from '../lib/woocommerce.js';

const rawProductId    = Astro.url.searchParams.get('product') ?? '';
const numericProductId = rawProductId && /^\d+$/.test(rawProductId) ? Number(rawProductId) : 0;

let product = null;

if (numericProductId > 0) {
  product = await getProductById(numericProductId);
}
---

<BaseLayout
  title="إتمام الطلب - دكان البنات"
  description="أكملي بياناتك لإتمام طلبك في دكان البنات."
>
  <main>
    <section class="checkout-page" dir="rtl">
      <div class="checkout-page__container">
        <a class="checkout-page__back" href="/products">← العودة للمنتجات</a>

        <header class="checkout-page__header">
          <span class="ds-section-label">إتمام الطلب</span>
          <h1>بيانات بسيطة ونُرسل لك المنتج</h1>
          <p>ستصل تفاصيل المنتج إلى بريدك الإلكتروني مباشرةً. لا يوجد دفع لهذا المنتج.</p>
        </header>

        <div class="checkout-page__layout">
          <form
            class="checkout-form"
            id="db-checkout-form"
            novalidate
            aria-label="نموذج الطلب"
          >
            <input type="text" name="website" class="checkout-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

            <div class="checkout-panel">
              <h2>بيانات التواصل</h2>

              <label class="ds-form-group" for="db-first-name">
                <span class="ds-form-group__label">
                  الاسم <span class="ds-form-group__required" aria-label="مطلوب">*</span>
                </span>
                <input
                  class="ds-input"
                  id="db-first-name"
                  name="first_name"
                  type="text"
                  autocomplete="given-name"
                  required
                  aria-required="true"
                  aria-describedby="db-first-name-error"
                />
                <span class="ds-form-group__error" id="db-first-name-error" role="alert" aria-live="assertive"></span>
              </label>

              <label class="ds-form-group" for="db-email">
                <span class="ds-form-group__label">
                  البريد الإلكتروني <span class="ds-form-group__required" aria-label="مطلوب">*</span>
                </span>
                <input
                  class="ds-input"
                  id="db-email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  inputmode="email"
                  required
                  aria-required="true"
                  aria-describedby="db-email-error"
                />
                <span class="ds-form-group__error" id="db-email-error" role="alert" aria-live="assertive"></span>
              </label>

              <label class="ds-form-group" for="db-phone">
                <span class="ds-form-group__label">رقم الهاتف (اختياري)</span>
                <input
                  class="ds-input"
                  id="db-phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  inputmode="tel"
                  aria-describedby="db-phone-error"
                />
                <span class="ds-form-group__error" id="db-phone-error" role="alert" aria-live="assertive"></span>
              </label>
            </div>

            <div class="checkout-panel">
              <h2>الموافقة والشروط</h2>

              <label class="ds-form-group ds-form-group--checkbox">
                <input
                  class="ds-checkbox"
                  id="db-privacy"
                  name="privacy_accepted"
                  type="checkbox"
                  required
                  aria-required="true"
                  aria-describedby="db-privacy-error"
                />
                <span>
                  أوافق على
                  <a href="/privacy" target="_blank" rel="noopener">سياسة الخصوصية</a>
                  و<a href="/terms" target="_blank" rel="noopener">شروط الاستخدام</a>
                  اللازمة لإتمام الطلب وإرسال المنتج.
                  <span class="ds-form-group__required" aria-label="مطلوب">*</span>
                </span>
              </label>
              <span class="ds-form-group__error" id="db-privacy-error" role="alert" aria-live="assertive"></span>

              <label class="ds-form-group ds-form-group--checkbox" style="margin-top: var(--space-4);">
                <input
                  class="ds-checkbox"
                  id="db-marketing"
                  name="marketing_consent"
                  type="checkbox"
                />
                <span>أرغب في تلقي رسائل عن المنتجات والعروض الجديدة (اختياري).</span>
              </label>
            </div>

            <div class="checkout-message" id="db-checkout-message" role="status" aria-live="polite" hidden></div>

            <button
              class="ds-btn ds-btn--primary-solid ds-btn--lg ds-btn--pill checkout-submit"
              type="submit"
              id="db-submit"
            >
              <span class="checkout-submit__label">احصلي على المنتج مجانًا</span>
              <span class="checkout-submit__loading" hidden aria-hidden="true">جارٍ المعالجة...</span>
            </button>

            <p class="checkout-note">لا يوجد دفع — المنتج مجاني تمامًا.</p>
          </form>

          <aside class="checkout-summary" aria-labelledby="checkout-summary-heading">
            <h2 id="checkout-summary-heading">ملخص الطلب</h2>
            {product ? (
              <article class="checkout-item">
                {product.image ? (
                  <img
                    src={product.image.src}
                    alt={product.image.alt}
                    class="checkout-item__img"
                    loading="lazy"
                  />
                ) : (
                  <div class="checkout-item__placeholder" aria-hidden="true">
                    <span>غلاف المنتج</span>
                  </div>
                )}
                <div class="checkout-item__details">
                  <h3>{product.name}</h3>
                  {product.shortDescription && (
                    <p>{product.shortDescription}</p>
                  )}
                  <strong class="checkout-item__price">
                    {product.price === 'مجاني' ? 'مجاني' : product.price}
                  </strong>
                </div>
              </article>
              <dl class="checkout-total">
                <div>
                  <dt>الإجمالي</dt>
                  <dd>مجاني</dd>
                </div>
              </dl>
            ) : (
              <p class="checkout-empty">
                لم يتم اختيار منتج. <a href="/products">تصفحي المنتجات</a>
              </p>
            )}

            <div class="checkout-recovery-hint">
              <p>إذا لم تصل رسالة التأكيد، يمكنك <a href="/recover-download">استعادة طلبك لاحقًا</a> برقم الطلب والبريد الإلكتروني.</p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ serverProductId: product?.id ?? null }}>
  const form = document.getElementById('db-checkout-form');
  const submitBtn = document.getElementById('db-submit');
  const submitLabel = submitBtn?.querySelector('.checkout-submit__label');
  const submitLoading = submitBtn?.querySelector('.checkout-submit__loading');
  const msgEl = document.getElementById('db-checkout-message');

  function generateIdempotencyKey() {
    const arr = new Uint8Array(16);
    crypto.getRandomValues(arr);
    return Array.from(arr, (b) => b.toString(16).padStart(2, '0')).join('');
  }

  let idempotencyKey = generateIdempotencyKey();
  let submitting = false;

  function setMessage(text, type = 'info') {
    if (!msgEl) return;
    msgEl.textContent = text;
    msgEl.dataset.type = type;
    msgEl.hidden = !text;
  }

  function clearFieldError(id) {
    const el = document.getElementById(id);
    if (el) el.textContent = '';
  }

  function setFieldError(id, msg) {
    const el = document.getElementById(id);
    if (el) el.textContent = msg;
  }

  function setLoading(on) {
    if (!submitBtn) return;
    submitBtn.disabled = on;
    submitLabel?.toggleAttribute('hidden', on);
    submitLoading?.toggleAttribute('hidden', !on);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitting) return;

    clearFieldError('db-first-name-error');
    clearFieldError('db-email-error');
    clearFieldError('db-phone-error');
    clearFieldError('db-privacy-error');
    setMessage('');

    const data = new FormData(form);

    if (data.get('website')) return;

    const firstName = (data.get('first_name') ?? '').toString().trim();
    const email = (data.get('email') ?? '').toString().trim();
    const phone = (data.get('phone') ?? '').toString().trim();
    const privacyAccepted = !!data.get('privacy_accepted');
    const marketingConsent = !!data.get('marketing_consent');

    let valid = true;

    if (!firstName) {
      setFieldError('db-first-name-error', 'الاسم مطلوب.');
      valid = false;
    }

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setFieldError('db-email-error', 'يرجى إدخال بريد إلكتروني صحيح.');
      valid = false;
    }

    if (!privacyAccepted) {
      setFieldError('db-privacy-error', 'يجب الموافقة على سياسة الخصوصية والشروط لإتمام الطلب.');
      valid = false;
    }

    if (!valid) return;

    const productId = serverProductId;
    if (!productId) {
      setMessage('لم يتم تحديد المنتج. يرجى العودة واختيار المنتج مرة أخرى.', 'error');
      return;
    }

    submitting = true;
    setLoading(true);
    setMessage('جارٍ إرسال طلبك...');

    try {
      const res = await fetch('/api/checkout/free', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          product_id: productId,
          first_name: firstName,
          email,
          phone: phone || undefined,
          marketing_consent: marketingConsent,
          privacy_accepted: privacyAccepted,
          idempotency_key: idempotencyKey,
        }),
      });

      const json = await res.json().catch(() => ({}));

      if (res.ok && json.success) {
        const params = new URLSearchParams({
          order: json.order_number ?? '',
          email: json.masked_email ?? '',
        });
        window.location.href = `/order-confirmation?${params}`;
        return;
      }

      const msg = typeof json.message === 'string' ? json.message : 'حدث خطأ، يرجى المحاولة مرة أخرى.';
      setMessage(msg, 'error');
      idempotencyKey = generateIdempotencyKey();
    } catch {
      setMessage('تعذّر إرسال الطلب. تحققي من اتصالك بالإنترنت وحاولي مرة أخرى.', 'error');
      idempotencyKey = generateIdempotencyKey();
    } finally {
      submitting = false;
      setLoading(false);
    }
  });
</script>

<style>
  .checkout-honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .checkout-page {
    background: var(--color-bg-base);
    padding-block: var(--space-12) var(--space-16);
  }

  .checkout-page__container {
    max-width: var(--grid-max-width);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .checkout-page__back {
    display: inline-block;
    margin-bottom: var(--space-8);
    font: var(--type-ar-body-sm);
    color: var(--color-primary);
    text-decoration: none;
  }

  .checkout-page__header {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  .checkout-page__header h1 {
    font: var(--type-ar-h2);
    color: var(--color-text-primary);
    margin: var(--space-4) 0;
  }

  .checkout-page__header p {
    font: var(--type-ar-body-lg);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .checkout-page__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: var(--space-8);
    align-items: start;
  }

  .checkout-form {
    display: grid;
    gap: var(--space-5);
    position: relative;
  }

  .checkout-panel {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    padding: var(--space-6);
    display: grid;
    gap: var(--space-5);
  }

  .checkout-panel h2 {
    font: var(--type-ar-h5);
    color: var(--color-text-primary);
    margin: 0;
  }

  .ds-form-group {
    display: grid;
    gap: var(--space-2);
  }

  .ds-form-group--checkbox {
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: start;
    cursor: pointer;
  }

  .ds-form-group__label {
    font: var(--type-ar-body-sm);
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .ds-form-group__required {
    color: var(--color-error, #ef4444);
  }

  .ds-form-group__error {
    font: var(--type-ar-caption, 0.8rem/1.4 inherit);
    color: var(--color-error, #ef4444);
    min-height: 1.2em;
  }

  .checkout-message {
    padding: var(--space-4);
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-canvas);
    font: var(--type-ar-body-sm);
    color: var(--color-text-secondary);
  }

  .checkout-message[data-type="error"] {
    border-color: var(--color-error, #ef4444);
    color: var(--color-error, #ef4444);
  }

  .checkout-message[data-type="success"] {
    border-color: var(--color-success, #22c55e);
    color: var(--color-success, #22c55e);
  }

  .checkout-submit {
    justify-self: start;
  }

  .checkout-note {
    font: var(--type-ar-caption, 0.8rem/1.4 inherit);
    color: var(--color-text-muted);
    margin: 0;
  }

  .checkout-summary {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    padding: var(--space-6);
    display: grid;
    gap: var(--space-4);
  }

  .checkout-summary h2 {
    font: var(--type-ar-h5);
    color: var(--color-text-primary);
    margin: 0;
  }

  .checkout-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .checkout-item__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: var(--color-bg-canvas);
  }

  .checkout-item__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-canvas);
    border: 1px solid var(--color-border-default);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .checkout-item__details h3 {
    font: var(--type-ar-h6);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
  }

  .checkout-item__details p {
    font: var(--type-ar-body-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-2);
  }

  .checkout-item__price {
    font: var(--type-ar-h6);
    color: var(--color-primary);
  }

  .checkout-total {
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-default);
  }

  .checkout-total div {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    font: var(--type-ar-h6);
    color: var(--color-text-primary);
  }

  .checkout-total dt,
  .checkout-total dd {
    margin: 0;
  }

  .checkout-empty {
    font: var(--type-ar-body);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .checkout-recovery-hint {
    border-top: 1px solid var(--color-border-default);
    padding-top: var(--space-4);
    font: var(--type-ar-body-sm);
    color: var(--color-text-muted);
  }

  .checkout-recovery-hint a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .checkout-page__layout {
      grid-template-columns: 1fr;
    }

    .checkout-summary {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .checkout-item {
      grid-template-columns: 80px 1fr;
    }
  }
</style>
