---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../lib/wordpress.js';

const posts = await getAllPosts(100);

function stripHtml(html) {
  return html.replace(/<[^>]*>/g, '').trim();
}

function truncate(text, len = 90) {
  return text.length > len ? text.slice(0, len).trimEnd() + '…' : text;
}
---

<BaseLayout
  title="مجلة دكان البنات — كل المقالات"
  description="تصفحي كل مقالات مجلة دكان البنات — جمال، بيزنس، وأسلوب حياة للمرأة العربية"
>
  <main>

    <!-- ── Page header ── -->
    <section class="archive-header ds-section-enter" aria-labelledby="archive-heading">
      <div class="archive-header__inner">
        <a class="archive-back" href="/">← الرئيسية</a>
        <span class="ds-section-label" style="display:block;margin-bottom:var(--space-3);">
          متابعة مستجدات البنات
        </span>
        <h1 id="archive-heading">مجلة دكان البنات</h1>
        <p class="archive-header__sub">أحدث المقالات، الاتجاهات، والمحتوى المختار لكل بنت واعية</p>
        {posts.length > 0 && (
          <p class="archive-count">{posts.length} مقال</p>
        )}
      </div>
    </section>

    <!-- ── Posts grid ── -->
    <section class="archive-section">
      <div class="archive-container">
        {posts.length > 0 ? (
          <div class="archive-grid">
            {posts.map((post) => {
              const img = post._embedded?.['wp:featuredmedia']?.[0];
              const cat = post._embedded?.['wp:term']?.[0]?.[0]?.name;
              const excerpt = truncate(stripHtml(post.excerpt?.rendered ?? ''));
              const date = new Date(post.date).toLocaleDateString('ar-SA', {
                year: 'numeric', month: 'long', day: 'numeric',
              });
              return (
                <article class="arc-card">
                  {img?.source_url && (
                    <a href={`/blog/${post.slug}`} class="arc-card__img-link" tabindex="-1" aria-hidden="true">
                      <img
                        src={img.source_url}
                        alt={img.alt_text || ''}
                        loading="lazy"
                        class="arc-card__img"
                      />
                    </a>
                  )}
                  <div class="arc-card__body">
                    {cat && <span class="arc-card__cat">{cat}</span>}
                    <h2 class="arc-card__title">
                      <a href={`/blog/${post.slug}`} set:html={post.title.rendered} />
                    </h2>
                    {excerpt && <p class="arc-card__excerpt">{excerpt}</p>}
                    <time class="arc-card__date" datetime={post.date}>{date}</time>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <!-- Skeleton while data loads -->
          <div class="archive-grid">
            {[...Array(6)].map(() => (
              <article class="arc-card arc-card--skel">
                <div class="arc-skel arc-skel--img" />
                <div class="arc-card__body">
                  <div class="arc-skel arc-skel--label" />
                  <div class="arc-skel arc-skel--title" />
                  <div class="arc-skel arc-skel--title arc-skel--w70" />
                  <div class="arc-skel arc-skel--text" />
                  <div class="arc-skel arc-skel--text arc-skel--w60" />
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* ── Header ── */
  .archive-header {
    background: var(--gradient-hero);
    padding-block: var(--space-20) var(--space-16);
    text-align: center;
  }

  .archive-header__inner {
    max-width: var(--grid-max-width);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .archive-back {
    display: inline-block;
    margin-bottom: var(--space-8);
    font: var(--type-ar-body-sm);
    letter-spacing: var(--letter-spacing-ar-body-sm);
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--duration-quick) var(--ease-editorial);
  }

  .archive-back:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .archive-header h1 {
    font: var(--type-ar-display);
    letter-spacing: var(--letter-spacing-ar-display);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4);
  }

  .archive-header__sub {
    font: var(--type-ar-body-lg);
    letter-spacing: var(--letter-spacing-ar-body-lg);
    color: var(--color-text-secondary);
    margin: 0 auto var(--space-4);
    max-width: 540px;
  }

  .archive-count {
    font: var(--type-ar-body-sm);
    letter-spacing: var(--letter-spacing-ar-body-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Section ── */
  .archive-section {
    padding-block: var(--space-16);
    background: var(--color-bg-base);
  }

  .archive-container {
    max-width: var(--grid-max-width);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  /* ── Grid ── */
  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  /* ── Card ── */
  .arc-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--duration-default) var(--ease-editorial),
                transform var(--duration-default) var(--ease-editorial);
  }

  .arc-card:hover {
    box-shadow: var(--shadow-dropdown);
    transform: translateY(-2px);
  }

  .arc-card__img-link {
    display: block;
    flex-shrink: 0;
  }

  .arc-card__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .arc-card__body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .arc-card__cat {
    font: var(--type-ar-label);
    letter-spacing: var(--letter-spacing-ar-label);
    color: var(--color-primary);
  }

  .arc-card__title {
    font: var(--type-ar-h6);
    letter-spacing: var(--letter-spacing-ar-h6);
    color: var(--color-text-primary);
    margin: 0;
  }

  .arc-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-quick) var(--ease-editorial);
  }

  .arc-card__title a:hover,
  .arc-card__title a:focus-visible {
    color: var(--color-primary);
  }

  .arc-card__title a:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  .arc-card__excerpt {
    font: var(--type-ar-body-sm);
    letter-spacing: var(--letter-spacing-ar-body-sm);
    color: var(--color-text-secondary);
    margin: 0;
    flex: 1;
  }

  .arc-card__date {
    font: var(--type-ar-caption);
    letter-spacing: var(--letter-spacing-ar-caption);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  /* ── Skeleton ── */
  @keyframes arc-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .arc-skel {
    background: var(--color-border-default);
    border-radius: var(--radius-sm);
    animation: arc-pulse 1.5s ease-in-out infinite;
  }

  .arc-skel--img   { width: 100%; aspect-ratio: 4 / 3; border-radius: 0; flex-shrink: 0; }
  .arc-skel--label { height: var(--space-3); width: 4rem; }
  .arc-skel--title { height: var(--space-5); width: 100%; }
  .arc-skel--text  { height: var(--space-3); width: 100%; }
  .arc-skel--w70   { width: 70%; }
  .arc-skel--w60   { width: 60%; }

  @media (prefers-reduced-motion: reduce) {
    .arc-card { transition: none; }
    .arc-skel { animation: none; opacity: 0.6; }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .archive-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }

  @media (max-width: 640px) {
    .archive-header {
      padding-block: var(--space-12) var(--space-10);
    }

    .archive-header h1 {
      font: var(--type-ar-h2);
      letter-spacing: var(--letter-spacing-ar-h2);
    }

    .archive-section {
      padding-block: var(--space-10);
    }

    .archive-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
