---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="تأكيد الطلب - دكان البنات"
  description="تم استلام طلبك في دكان البنات. ستصل تفاصيل المنتج إلى بريدك الإلكتروني."
>
  <main>
    <section class="confirmation-page">
      <div class="confirmation-page__container">
        <div class="confirmation-card" id="db-confirmation-card">
          <div class="confirmation-icon" aria-hidden="true">✓</div>
          <h1 class="confirmation-title">تم استلام طلبك!</h1>
          <p class="confirmation-subtitle" id="db-order-line">جارٍ تحميل تفاصيل الطلب...</p>
          <p class="confirmation-email" id="db-email-line"></p>

          <div class="confirmation-info">
            <p>سيصل رابط التحميل إلى بريدك الإلكتروني خلال دقائق.</p>
            <p>
              إذا لم تجدي الرسالة في البريد الوارد، تحققي من مجلد الرسائل غير المرغوب فيها (Spam).
            </p>
          </div>

          <div class="confirmation-recovery">
            <p>
              هل فقدت رابط التحميل؟
              <a href="/recover-download">استعيدي طلبك هنا</a>
            </p>
          </div>

          <a class="ds-btn ds-btn--primary-solid ds-btn--pill confirmation-cta" href="/products">
            تصفحي المزيد من المنتجات
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const orderNumber = params.get('order');
  const maskedEmail = params.get('email');

  const orderLine = document.getElementById('db-order-line');
  const emailLine = document.getElementById('db-email-line');

  if (orderNumber && orderLine) {
    orderLine.textContent = `رقم طلبك: ${orderNumber}`;
  } else if (orderLine) {
    orderLine.textContent = 'طلبك قيد المعالجة.';
  }

  if (maskedEmail && emailLine) {
    emailLine.textContent = `سيصل التأكيد إلى: ${maskedEmail}`;
  }
</script>

<style>
  .confirmation-page {
    background: var(--color-bg-base);
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-16);
  }

  .confirmation-page__container {
    max-width: 600px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    width: 100%;
  }

  .confirmation-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    padding: var(--space-10);
    text-align: center;
    display: grid;
    gap: var(--space-4);
  }

  .confirmation-icon {
    width: 64px;
    height: 64px;
    background: var(--color-success, #22c55e);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin-inline: auto;
  }

  .confirmation-title {
    font: var(--type-ar-h2);
    color: var(--color-text-primary);
    margin: 0;
  }

  .confirmation-subtitle {
    font: var(--type-ar-h5);
    color: var(--color-text-primary);
    margin: 0;
  }

  .confirmation-email {
    font: var(--type-ar-body);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .confirmation-info {
    background: var(--color-bg-canvas);
    border: 1px solid var(--color-border-default);
    padding: var(--space-4);
    text-align: start;
  }

  .confirmation-info p {
    font: var(--type-ar-body-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-2);
  }

  .confirmation-info p:last-child {
    margin-bottom: 0;
  }

  .confirmation-recovery {
    font: var(--type-ar-body-sm);
    color: var(--color-text-secondary);
  }

  .confirmation-recovery a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .confirmation-cta {
    justify-self: center;
  }
</style>
