---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="الصفحة غير موجودة — دكان البنات" description="الصفحة التي تبحثين عنها غير موجودة">
  <main class="ds-section" style="min-height:70vh;display:flex;align-items:center;">
    <div class="ds-container" style="text-align:center;padding-block:var(--space-24);">
      <p class="ds-section-label" style="justify-content:center;">خطأ ٤٠٤</p>
      <h1 style="margin-top:var(--space-4);margin-bottom:var(--space-3);">
        الصفحة التي تبحثين عنها غير موجودة
      </h1>
      <p class="ds-hero__body" style="margin-inline:auto;margin-bottom:var(--space-8);">
        ربما تم نقل الصفحة أو حذفها
      </p>
      <a class="ds-btn ds-btn--primary-solid ds-btn--md ds-btn--pill" href="/">
        العودة للرئيسية
      </a>
    </div>
  </main>
</BaseLayout>
