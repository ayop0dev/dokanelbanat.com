    <!-- ═══════════════════════════════════════════════════════════════
         2. HERO SECTION
         ═══════════════════════════════════════════════════════════════ -->
    <section class="ds-hero" id="hero" aria-label="مقدمة الموقع">
      <div class="ds-hero__inner">
        <div class="ds-hero__content ds-section-enter">
          <h1 class="ds-section-label" style="margin-block:0;">منذ عام 2018</h1>
          <div class="ds-hero__title" style="display:flex;flex-direction:column;gap:var(--space-2);">
            <h1 style="margin:0;">
              دكان البنات</h1>
            <h2 lang="en" style="color:var(--color-primary);margin:0;font-family:var(--font-en);">
              Dokanelbanat.com</h2>
          </div>
          <p class="ds-hero__subtitle">أحدث مجتمع نسائي متكامل في المنطقة العربية</p>
          <p class="ds-hero__body">من البنات وإلى البنات. نبني مجتمع نسائي يتكامل في توافر كافة عناصر الدعم الحقيقي
            للمرأة ومن المرأة، بهدف دعم وتطوير نمط حياة المرأة العربية العصرية.</p>
          <div class="ds-hero__actions">
            <a class="ds-btn ds-btn--primary-solid ds-btn--xl ds-btn--pill" href="/blog">مجلة
              دكان البنات</a>
            <a class="ds-btn ds-btn--secondary-outline ds-btn--xl ds-btn--pill" href="#about">إعادة ضبط عقليتك</a>
          </div>
        </div>
        <div class="ds-hero__media ds-section-enter" style="position:relative;min-height:480px;">
          <div class="hero-sliders" aria-hidden="true">
            <!-- Slider: moves UP -->
            <div class="hero-slider hero-slider--up">
              <div class="hero-slider__track">
                <!-- Original set -->
                <div class="hero-slider__item">
                  <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=400&h=500&fit=crop&q=80" alt="صورة بنت" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                </div>
                <div class="hero-slider__item">
                  <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=400&h=500&fit=crop&q=80" alt="صورة بنت" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
