  <!-- Dark overlay -->
  <div id="canvas-overlay" aria-hidden="true"></div>

<style is:global>
  /* ── Menu trigger button ── */
  .canvas-trigger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--color-text-primary);
    z-index: 100;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .canvas-trigger:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* ── Side canvas panel ── */
  #side-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 100vh;
    background: #fff5fb;
    z-index: 9999;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    padding: 2rem 1.5rem;
    gap: 2rem;
    overflow-y: auto;
  }

  #side-canvas.is-open {
    transform: translateX(0);
  }

  /* ── Dark overlay ── */
  #canvas-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 9998;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  #canvas-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Logo area (section 1) ── */
  .canvas-logo-area {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .canvas-logo-area img {
    display: block;
  }

  /* Close button */
  #canvas-close {
    background: none;
    border: 1px solid rgba(0, 0, 0, 0.15);
    cursor: pointer;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    font-size: 1.4rem;
    line-height: 1;
    color: #1a1a1a;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }

  #canvas-close:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--color-primary);
  }

  /* ── Navigation (section 2) ── */
  #side-canvas nav {
    display: flex;
    flex-direction: column;
  }

  #side-canvas nav a {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: #1a1a1a;
    padding: 0.5rem 0;
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    transition: color 0.2s ease;
  }

  #side-canvas nav a:last-child {
    border-bottom: none;
  }

  #side-canvas nav a:hover {
    color: var(--color-primary);
  }

  /* ── Social icons row (section 3) ── */
  .canvas-social {
    display: flex;
    gap: 1rem;
    margin-top: auto;
  }

  .canvas-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    transition: color 0.2s ease;
  }

  .canvas-social a svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .canvas-social a:hover {
    color: var(--color-primary);
  }
</style>
