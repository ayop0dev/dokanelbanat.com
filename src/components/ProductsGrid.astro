---
import { getProducts } from '../lib/woocommerce.js';

const products = await getProducts(3);
const hasProducts = products.length > 0;
---

<section class="ds-landing-page__section ds-section" id="products" aria-labelledby="products-heading">
  <div class="ds-container">
    <div class="ds-section-enter" style="text-align:center;margin-bottom:var(--space-12);">
      <span class="ds-section-label">اختيارك التعليمي</span>
      <h2 id="products-heading" style="margin-top:var(--space-4);color:var(--color-text-primary);">
        منتجات رقمية مختارة
      </h2>
      <p class="ds-hero__body" style="margin-inline:auto;">
        أدوات عملية صممناها خصيصا لتختصري الوقت وتبدئي بثقة
      </p>
    </div>

    {hasProducts ? (
      <div class="ds-products-grid ds-stagger">
        {products.map((product) => (
          <article class="ds-product-card">
            <a class="ds-product-card__mockup" href={product.productUrl}>
              {product.image ? (
                <img src={product.image.src} alt={product.image.alt} loading="lazy" />
              ) : (
                <div class="product-card__placeholder">
                  <span>غلاف المنتج</span>
                </div>
              )}
            </a>

            {product.category && <span class="ds-product-card__category">{product.category}</span>}
            <h4 class="ds-product-card__title">{product.name}</h4>
            {product.shortDescription && <p class="ds-product-card__desc">{product.shortDescription}</p>}

            <div class="ds-product-card__footer">
              <span class:list={['ds-product-card__price', product.price === 'مجاني' && 'ds-product-card__price--free']}>
                {product.price}
              </span>
              <a class="ds-btn ds-btn--primary-solid ds-btn--sm" href={product.checkoutUrl}>
                {product.price === 'مجاني' ? 'احصلي عليه' : 'اشتري الآن'}
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="ds-products-grid ds-stagger" aria-hidden="true">
        {[1, 2, 3].map(() => (
          <article class="ds-product-card product-card--skel">
            <div class="ds-product-card__mockup product-skel product-skel--image" />
            <div class="product-skel product-skel--label" />
            <div class="product-skel product-skel--title" />
            <div class="product-skel product-skel--text" />
            <div class="product-skel product-skel--footer" />
          </article>
        ))}
      </div>
    )}

    <div class="ds-section-enter" style="text-align:center;margin-top:var(--space-12);">
      <a class="ds-btn ds-btn--secondary-outline ds-btn--md ds-btn--pill" href="/products">
        تصفحي كل المنتجات الرقمية
      </a>
    </div>
  </div>
</section>

<style>
  .product-card__placeholder {
    width: 80%;
    height: 80%;
    background: var(--color-bg-base);
    border: 1px solid var(--color-border-default);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card__placeholder span {
    font: var(--type-ar-caption);
    color: var(--color-text-muted);
  }

  .product-skel {
    background: var(--color-border-default);
    border-radius: var(--radius-sm);
    animation: product-pulse 1.5s ease-in-out infinite;
  }

  .product-skel--image {
    width: 100%;
    border-radius: 0;
  }

  .product-skel--label {
    height: var(--space-3);
    width: 4rem;
  }

  .product-skel--title {
    height: var(--space-5);
    width: 90%;
  }

  .product-skel--text {
    height: var(--space-4);
    width: 100%;
  }

  .product-skel--footer {
    height: var(--space-8);
    width: 70%;
    margin-top: auto;
  }

  @keyframes product-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-skel {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
