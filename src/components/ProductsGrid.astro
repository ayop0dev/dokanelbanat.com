    <!-- ═══════════════════════════════════════════════════════════════
         7. DIGITAL PRODUCTS SECTION
         ═══════════════════════════════════════════════════════════════ -->
    <section class="ds-landing-page__section ds-section" id="products" aria-labelledby="products-heading">
      <div class="ds-container">
        <div class="ds-section-enter" style="text-align:center;margin-bottom:var(--space-12);">
          <span class="ds-section-label">اختيارك التعليمي</span>
          <h2 id="products-heading" style="margin-top:var(--space-4);color:var(--color-text-primary);">
            منتجات رقمية مختارة</h2>
          <p class="ds-hero__body" style="margin-inline:auto;">أدوات عملية صممناها خصيصاً لتختصري الوقت وتبدئي بثقة</p>
        </div>

        <!-- NOTE: Product cards below are static placeholders.
             In Phase 3, fetch from academy.dokanelbanat.com REST API -->
        <div class="ds-products-grid ds-stagger">
          <!-- Product 1 -->
          <div class="ds-product-card">
            <div class="ds-product-card__mockup">
              <div
                style="width:80%;height:80%;background:var(--color-bg-base);border:1px solid var(--color-border-default);display:flex;align-items:center;justify-content:center;">
                <span style="font:var(--type-ar-caption);color:var(--color-text-muted);">غلاف المنتج</span>
              </div>
            </div>
            <span class="ds-product-card__category">قالب</span>
            <h4 class="ds-product-card__title">خطة محتوى شهرية احترافية</h4>
            <p class="ds-product-card__desc">قابل للتعديل فوراً — يناسب كل مجال ويوفر ساعات من التخطيط.</p>
            <div class="ds-product-card__footer">
              <span class="ds-product-card__price">مجاني</span>
              <a class="ds-btn ds-btn--primary-solid ds-btn--sm" href="https://academy.dokanelbanat.com">احصلي عليه</a>
            </div>
          </div>

          <!-- Product 2 -->
          <div class="ds-product-card">
            <div class="ds-product-card__mockup">
              <div
                style="width:80%;height:80%;background:var(--color-bg-base);border:1px solid var(--color-border-default);display:flex;align-items:center;justify-content:center;">
                <span style="font:var(--type-ar-caption);color:var(--color-text-muted);">غلاف المنتج</span>
              </div>
            </div>
            <span class="ds-product-card__category">دليل</span>
            <h4 class="ds-product-card__title">دليل بناء البراند من الصفر</h4>
            <p class="ds-product-card__desc">خطوات عملية من الفكرة إلى الهوية البصرية الكاملة لعلامتك التجارية.</p>
            <div class="ds-product-card__footer">
              <span class="ds-product-card__price">$29</span>
              <a class="ds-btn ds-btn--primary-solid ds-btn--sm" href="https://academy.dokanelbanat.com">اشترِ الآن</a>
            </div>
          </div>

          <!-- Product 3 -->
          <div class="ds-product-card">
            <div class="ds-product-card__mockup">
              <div
                style="width:80%;height:80%;background:var(--color-bg-base);border:1px solid var(--color-border-default);display:flex;align-items:center;justify-content:center;">
                <span style="font:var(--type-ar-caption);color:var(--color-text-muted);">غلاف المنتج</span>
              </div>
            </div>
            <span class="ds-product-card__category">كتاب إلكتروني</span>
            <h4 class="ds-product-card__title">نظام الجمال الداخلي</h4>
            <p class="ds-product-card__desc">رحلة واعية لاكتشاف علاقتك بجمالك بعيداً عن الضغوط الاستهلاكية.</p>
            <div class="ds-product-card__footer">
              <span class="ds-product-card__price">$15</span>
              <a class="ds-btn ds-btn--primary-solid ds-btn--sm" href="https://academy.dokanelbanat.com">اشترِ الآن</a>
            </div>
          </div>
        </div>

        <div class="ds-section-enter" style="text-align:center;margin-top:var(--space-12);">
          <a class="ds-btn ds-btn--secondary-outline ds-btn--md ds-btn--pill"
            href="https://academy.dokanelbanat.com">تصفحي كل المنتجات الرقمية</a>
        </div>
      </div>
    </section>
